generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────
// DB stores these as VARCHAR with CHECK constraints; Prisma uses String.
// TypeScript enums live in src/common/enums/.

// AccountType values: NO_TYPE | BANK | CASH | ASSET | CREDIT_CARD | LIABILITY | CHECKING | SAVINGS
// AccountTemplate values: NONE | STANDARD_TRANSACTIONS | INCOME_TRACKING | EXPENSE_TRACKING
// CategoryType values: INCOME | EXPENSE | TRANSFER
// TransactionType values: INCOME | EXPENSE | TRANSFER
// TransactionStatus values: PENDING | CLEARED | VOID

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id            BigInt          @id @default(autoincrement())
  username      String?         @unique(map: "uk_users_username") @db.VarChar(50)
  email         String?         @unique(map: "uk_users_email") @db.VarChar(150)
  passwordHash  String?         @map("password_hash") @db.VarChar(255)
  fullName      String?         @map("full_name") @db.VarChar(100)
  language      String?         @default("en") @db.VarChar(10)
  onboardingState Json?         @map("onboarding_state")
  isActive      Boolean?        @map("is_active")
  createdAt     DateTime?       @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?       @updatedAt @map("updated_at") @db.Timestamptz(6)

  accounts             Account[]
  transactions         Transaction[]
  userCategories       UserCategory[]
  userCurrencies       UserCurrency[]
  budgets              Budget[]
  goals                Goal[]
  passwordResetTokens  PasswordResetToken[]
  recurringTransactions RecurringTransaction[]
  attachments          Attachment[]
  notifications        Notification[]

  @@map("users")
}

model PasswordResetToken {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_prt_user")

  @@index([userId], map: "idx_prt_user_id")
  @@map("password_reset_tokens")
}

/// This table contains check constraints. Visit https://pris.ly/d/check-constraints for more info.
model Account {
  id                        BigInt   @id @default(autoincrement())
  name                      String   @db.VarChar(100)
  institution               String?  @db.VarChar(150)
  type                      String   @default("NO_TYPE") @db.VarChar(20)
  accountNumber             String?  @map("account_number") @db.VarChar(50)
  currencyId                BigInt?  @map("currency_id")
  groupName                 String?  @map("group_name") @db.VarChar(100)
  startBalance              Decimal? @default(0) @map("start_balance") @db.Decimal(15, 2)
  notes                     String?
  icon                      String?  @db.VarChar(50)
  isClosed                  Boolean? @default(false) @map("is_closed")
  isActive                  Boolean? @default(true) @map("is_active")
  defaultTemplate           String   @default("NONE") @map("default_template") @db.VarChar(30)
  excludeFromAccountSummary Boolean? @default(false) @map("exclude_from_account_summary")
  outlineIntoSummary        Boolean? @default(false) @map("outline_into_summary")
  excludeFromBudget         Boolean? @default(false) @map("exclude_from_budget")
  excludeFromAnyReports     Boolean? @default(false) @map("exclude_from_any_reports")
  overdraftAt               Decimal? @default(0) @map("overdraft_at") @db.Decimal(15, 2)
  maximumBalance            Decimal? @default(0) @map("maximum_balance") @db.Decimal(15, 2)
  checkbook1                Int?     @default(0)
  checkbook2                Int?     @default(0)
  userId                    BigInt   @map("user_id")
  createdAt                 DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  currency     Currency?     @relation(fields: [currencyId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_account_currency")
  user         User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_account_user")
  transactions Transaction[]
  recurringTransactions            RecurringTransaction[] @relation("RecurringSourceAccount")
  recurringDestinationTransactions RecurringTransaction[] @relation("RecurringDestinationAccount")
  goals                            Goal[]

  @@map("accounts")
}

/// This table contains check constraints. Visit https://pris.ly/d/check-constraints for more info.
model Category {
  id        BigInt    @id @default(autoincrement())
  type      String    @db.VarChar(20)
  name      String    @db.VarChar(100)
  icon      String?   @db.VarChar(50)
  parentId  BigInt?   @map("parent_id")
  createdAt DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent            Category?             @relation("CategoryParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_category_parent")
  children          Category[]            @relation("CategoryParent")
  translations      CategoryTranslation[]
  userCategories    UserCategory[]

  @@map("categories")
}

model CategoryTranslation {
  id         BigInt    @id @default(autoincrement())
  categoryId BigInt    @map("category_id")
  language   String    @db.VarChar(10)
  name       String    @db.VarChar(100)
  createdAt  DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  category Category @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ct_category")

  @@unique([categoryId, language], map: "uq_ct_category_language")
  @@map("category_translations")
}

model Currency {
  id        BigInt    @id @default(autoincrement())
  code      String    @unique(map: "uk_currencies_code") @db.VarChar(3)
  name      String    @db.VarChar(120)
  symbol    String?   @db.VarChar(10)
  createdAt DateTime? @map("created_at") @db.Timestamptz(6)

  accounts        Account[]
  userCurrencies  UserCurrency[]

  @@map("currencies")
}

/// This table contains check constraints. Visit https://pris.ly/d/check-constraints for more info.
model Transaction {
  id            BigInt    @id @default(autoincrement())
  userId        BigInt    @map("user_id")
  accountId     BigInt    @map("account_id")
  categoryId    BigInt?   @map("category_id")
  type          String    @db.VarChar(20)
  amount        Decimal   @db.Decimal(15, 2)
  effectiveDate DateTime  @map("effective_date") @db.Date
  payee         String?   @db.VarChar(255)
  paymentMethod String?   @map("payment_method") @db.VarChar(100)
  memo          String?
  status        String    @default("CLEARED") @db.VarChar(20)
  tags          String?
  transferGroupId   String?   @map("transfer_group_id") @db.Uuid
  transferAccountId BigInt?   @map("transfer_account_id")
  transferIn        Boolean?  @map("transfer_in")
  exchangeRate      Decimal?  @map("exchange_rate") @db.Decimal(15, 6)
  createdAt     DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  account      Account       @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transaction_account")
  userCategory UserCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transaction_category")
  user         User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transaction_user")
  attachments Attachment[]
  splits       TransactionSplit[]

  @@index([accountId], map: "idx_transactions_account_id")
  @@index([effectiveDate], map: "idx_transactions_effective_date")
  @@index([userId], map: "idx_transactions_user_id")
  @@index([transferGroupId], map: "idx_transactions_transfer_group_id")
  @@map("transactions")
}

/// This table contains check constraints. Visit https://pris.ly/d/check-constraints for more info.
model UserCategory {
  id               BigInt    @id @default(autoincrement())
  type             String    @db.VarChar(20)
  name             String    @db.VarChar(100)
  icon             String?   @db.VarChar(50)
  isActive         Boolean?  @map("is_active")
  isCustom         Boolean?  @map("is_custom")
  parentId         BigInt?   @map("parent_id")
  sourceCategoryId BigInt?   @map("source_category_id")
  userId           BigInt    @map("user_id")
  createdAt        DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  transactions    Transaction[]
  parent          UserCategory?  @relation("UserCategoryParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_uc_parent_category")
  children        UserCategory[] @relation("UserCategoryParent")
  sourceCategory  Category?      @relation(fields: [sourceCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_uc_source_category")
  user            User           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_uc_user_category")
  budgets         Budget[]
  recurringTransactions RecurringTransaction[]
  splits          TransactionSplit[]

  @@map("user_categories")
}

model Budget {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  categoryId BigInt    @map("category_id")
  amount     Decimal   @db.Decimal(15, 2)
  period     String    @default("MONTHLY") @db.VarChar(20)
  startDate  DateTime  @map("start_date") @db.Date
  isActive   Boolean?  @default(true) @map("is_active")
  createdAt  DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_budget_user")
  category UserCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_budget_category")

  @@unique([userId, categoryId, period], map: "uq_budget_user_category_period")
  @@index([userId], map: "idx_budgets_user_id")
  @@map("budgets")
}

model Goal {
  id            BigInt    @id @default(autoincrement())
  userId        BigInt    @map("user_id")
  name          String    @db.VarChar(100)
  targetAmount  Decimal   @map("target_amount") @db.Decimal(15, 2)
  currentAmount Decimal   @default(0) @map("current_amount") @db.Decimal(15, 2)
  targetDate    DateTime? @map("target_date") @db.Date
  accountId     BigInt?   @map("account_id")
  isAchieved    Boolean   @default(false) @map("is_achieved")
  createdAt     DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_goal_user")
  account Account? @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_goal_account")

  @@index([userId], map: "idx_goals_user_id")
  @@map("goals")
}

/// This table contains check constraints. Visit https://pris.ly/d/check-constraints for more info.
model RecurringTransaction {
  id                  BigInt    @id @default(autoincrement())
  userId              BigInt    @map("user_id")
  accountId           BigInt    @map("account_id")
  categoryId          BigInt?   @map("category_id")
  destinationAccountId BigInt?  @map("destination_account_id")
  type                String    @db.VarChar(20)
  amount              Decimal   @db.Decimal(15, 2)
  frequency           String    @db.VarChar(20)
  interval            Int       @default(1)
  nextRunDate         DateTime  @map("next_run_date") @db.Date
  lastRunDate         DateTime? @map("last_run_date") @db.Date
  endDate             DateTime? @map("end_date") @db.Date
  payee               String?   @db.VarChar(255)
  memo                String?
  tags                String?
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  user                User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_recurring_user")
  account             Account       @relation("RecurringSourceAccount", fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_recurring_account")
  destinationAccount  Account?      @relation("RecurringDestinationAccount", fields: [destinationAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_recurring_destination_account")
  userCategory        UserCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_recurring_category")

  @@index([userId], map: "idx_recurring_user_id")
  @@index([nextRunDate, isActive], map: "idx_recurring_next_run_date")
  @@map("recurring_transactions")
}

model UserCurrency {
  currencyId   BigInt   @map("currency_id")
  userId       BigInt   @map("user_id")
  exchangeRate Decimal? @map("exchange_rate") @db.Decimal(15, 6)
  isBase       Boolean? @map("is_base")
  isActive     Boolean? @map("is_active")
  createdAt    DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  currency Currency @relation(fields: [currencyId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_uc_currency")
  user     User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_uc_user")

  @@id([currencyId, userId])
  @@map("user_currencies")
}

model Attachment {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @map("user_id")
  transactionId BigInt   @map("transaction_id")
  fileName      String   @map("file_name") @db.VarChar(255)
  mimeType      String   @map("mime_type") @db.VarChar(80)
  sizeBytes     Int      @map("size_bytes")
  storageKey    String   @unique @map("storage_key") @db.VarChar(64)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User        @relation(fields: [userId],        references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId], map: "idx_attachments_transaction_id")
  @@index([userId],        map: "idx_attachments_user_id")
  @@map("attachments")
}

model TransactionSplit {
  id            BigInt    @id @default(autoincrement())
  transactionId BigInt    @map("transaction_id")
  categoryId    BigInt    @map("category_id")
  amount        Decimal   @db.Decimal(15, 2)
  memo          String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  transaction Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    UserCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([transactionId], map: "idx_transaction_splits_transaction_id")
  @@index([categoryId], map: "idx_transaction_splits_category_id")
  @@map("transaction_splits")
}

model Notification {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  type       String    @db.VarChar(40)
  title      String    @db.VarChar(255)
  body       String
  dedupeKey  String    @map("dedupe_key") @db.VarChar(120)
  isRead     Boolean?  @default(false) @map("is_read")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey], map: "uq_notifications_user_dedupe")
  @@index([userId, isRead], map: "idx_notifications_user_unread")
  @@index([userId, createdAt], map: "idx_notifications_user_created_at")
  @@map("notifications")
}
