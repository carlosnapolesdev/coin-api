# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL: same schema used by the Spring Boot backend (coinflow)
DATABASE_URL="postgresql://postgres:password@localhost:5432/coinflow"

# ── JWT ────────────────────────────────────────────────────────────────────────
# Signing secret — REQUIRED, no default value
JWT_SECRET=

# Token expiration (ms). Default: 1 hour
JWT_EXPIRATION_MS=3600000

# "Remember me" token expiration (ms). Default: 7 days
JWT_REMEMBER_ME_EXPIRATION_MS=604800000

# Token issuer. Default: coinflow
JWT_ISSUER=coinflow

# ── Seeds ──────────────────────────────────────────────────────────────────────
# API token for aaapis.com — used to fetch the currency catalog
AAAPIS_TOKEN=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
