# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/crecik"

# ── JWT ────────────────────────────────────────────────────────────────────────
# Signing secret — REQUIRED, no default value
JWT_SECRET=

# Token expiration (ms). Default: 1 hour
JWT_EXPIRATION_MS=3600000

# "Remember me" token expiration (ms). Default: 7 days
JWT_REMEMBER_ME_EXPIRATION_MS=604800000

# Token issuer. Default: crecik
JWT_ISSUER=crecik

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. REQUIRED when NODE_ENV=production
# (startup fails otherwise). Leave empty in development to allow all origins.
# Example: CORS_ORIGIN=http://localhost:5173,https://myapp.com
CORS_ORIGIN=

# ── App ────────────────────────────────────────────────────────────────────────
# Frontend base URL used to build password-reset links. REQUIRED when
# NODE_ENV=production (startup fails otherwise). Default in development:
# http://localhost:5173
APP_URL=

# ── Google OAuth ───────────────────────────────────────────────────────────────
# OAuth 2.0 Web client ID from Google Auth Platform (ends in
# .apps.googleusercontent.com). Used to verify Google ID tokens (audience) and
# served to the frontend via GET /auth/google/config to render the sign-in
# button. REQUIRED when NODE_ENV=production (startup fails otherwise); leave
# empty in development to hide the Google button. The client secret is NOT used.
GOOGLE_CLIENT_ID=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# API key de Resend. Sin ella no sale ningún correo (se avisa al arrancar).
RESEND_API_KEY=

# Remitente. El dominio debe estar verificado en Resend.
MAIL_FROM="Crecik <no-reply@crecik.com>"

# Destinatario del digest de errores de cliente. Sin ella no se envía digest.
CLIENT_ERRORS_DIGEST_TO=

# ── Seeds ──────────────────────────────────────────────────────────────────────
# API token for aaapis.com — used to fetch the currency catalog
AAAPIS_TOKEN=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
